# STRATA v5 — Environment Configuration
# ========================================

# Anthropic API Key (optional — system works 100% free without it)
# Only needed if CLAUDE_ENABLED=true for AI-guided evolution
ANTHROPIC_API_KEY=
CLAUDE_ENABLED=false

# Evolution Core
POPULATION_SIZE=12           # Genomes per island (3 islands x 12 = 36 total)
WORKLOADS_PER_GENOME=60      # Simulation workloads per evaluation
MAX_GENERATIONS=10000        # Stop after N generations
SLEEP_BETWEEN_GENS=0.05      # Pause between gens (seconds)
STAGNATION_PATIENCE=15       # Gens without improvement before escape

# Claude AI Analysis (only if CLAUDE_ENABLED=true)
CLAUDE_EVERY_N=100           # Claude analysis frequency
DIAGNOSIS_EVERY_N=200        # Multi-strategy diagnosis frequency
SYNTHESIS_EVERY_N=1000       # Synthesis report frequency

# Island Model
MIGRATION_INTERVAL=20        # Migration between islands every N gens

# Ollama — Free Local LLM Validation
OLLAMA_HOST=http://localhost:11434   # Docker: http://ollama:11434
OLLAMA_MODEL=llama3.2:1b            # Local model for validation
OLLAMA_EVERY_N=100                  # Validate every N gens
OLLAMA_TOP_N=1                      # Top genomes to validate
OLLAMA_CASES=4                      # Benchmark cases per validation
OLLAMA_TIMEOUT=120                  # Timeout per call (seconds)
OLLAMA_NUM_PREDICT=256              # Max tokens per response

# Convergence Detection
CONVERGENCE_WINDOW=5000      # Window to check for convergence
CONVERGENCE_THRESHOLD=0.003  # Minimum fitness change threshold

# Email Notifications (optional)
# Gmail App-Passwort: https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
NOTIFY_EMAIL=
NOTIFY_EVERY_N=500
